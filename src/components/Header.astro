---
import { SITE_TITLE } from '../consts';
import HeaderLink from './HeaderLink.astro';
---
<header>
	<nav>
		<div class="logo-container align-absolute">
			<a href="/">
				<img id="logo-eye" src="/eye_green.png" alt="logo" />
			</a>
		</div>
		<div class="internal-links align-absolute">
			<div class="nav-links">
				<HeaderLink href="/">home</HeaderLink>
				<HeaderLink href="/videos">videos</HeaderLink>
			</div>
			<button id="theme-toggle" class="theme-switch" aria-label="Toggle Theme" title="Toggle light/dark theme">
				<img id="switch-img" src="/light_off.png" alt="light switch" />
			</button>
		</div>
	</nav>
</header>

<script>
	const eyes = ['/eye_green.png', '/eye_orange.png', '/eye_yellow.png'];
	const randomEye = eyes[Math.floor(Math.random() * eyes.length)];
	const logoImg = document.getElementById('logo-eye') as HTMLImageElement;
	if (logoImg) {
		logoImg.src = randomEye;
	}

	const toggle = document.getElementById('theme-toggle');
	const switchImg = document.getElementById('switch-img') as HTMLImageElement;
	const body = document.body;

	const updateSwitch = (theme: string) => {
		if (switchImg) {
			switchImg.src = theme === 'light-mode' ? '/light_on.png' : '/light_off.png';
		}
	};

	if (localStorage.getItem('theme') === 'light-mode') {
		body.classList.add('light-mode');
		updateSwitch('light-mode');
	}

	toggle?.addEventListener('click', () => {
		body.classList.toggle('light-mode');
		const theme = body.classList.contains('light-mode') ? 'light-mode' : 'dark-mode';
		updateSwitch(theme);
		localStorage.setItem('theme', theme);
	});
</script>

<style>
	header {
		padding: 2em 2em 4em 2em; /* Top padding matched to side padding */
		background: black;
        margin: 0;
        width: 100%;
	}
	:global(.light-mode) header {
		background: white;
	}
	.align-absolute {
		transform: translateY(50px);
	}
	.logo-container img {
		height: 80px;
		width: auto;
		display: block;
		border-radius: 12px;
	}
	nav {
		display: flex;
		align-items: center;
		justify-content: space-between;
	}
	.internal-links {
		display: flex;
		align-items: center;
		gap: 2.5em;
	}
	.nav-links {
		display: flex;
		gap: 1.5em;
	}
	nav a {
		color: white;
		text-decoration: none;
		text-transform: lowercase;
		font-family: 'Terminal Grotesque', sans-serif; /* Terminal font for nav */
		font-size: 1.5rem;
        display: flex;
        align-items: center;
        padding-bottom: 10px;
        transition: all 0.3s ease;
	}
	:global(.light-mode) nav a {
		color: black;
	}
	nav a:hover {
		text-shadow: 0px 0px 10px rgba(255, 255, 255, 0.8);
		border-bottom: 1px solid white;
	}
	:global(.light-mode) nav a:hover {
		text-shadow: 0px 0px 10px rgba(0, 0, 0, 0.2);
		border-bottom: 1px solid black;
	}
	nav a.active {
		border-bottom: 4px solid white;
        margin-bottom: 15px;
	}
	:global(.light-mode) nav a.active {
		border-bottom: 4px solid black;
	}
	.theme-switch {
		background: transparent;
		border: none;
		cursor: url("data:image/svg+xml;utf8,<svg xmlns='http://www.w3.org/2000/svg' width='40' height='48' viewport='0 0 100 100' style='fill:black;font-size:24px;'><text y='50%'>🍖</text></svg>") 16 0, pointer;
		display: flex;
		align-items: center;
		padding: 0;
        transform: translateY(10px);
	}
	.theme-switch img {
		height: 100px;
		width: auto;
		display: block;
	}
</style>
