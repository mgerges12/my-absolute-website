---
import { SITE_TITLE } from '../consts';
import HeaderLink from './HeaderLink.astro';
---
<header>
	<nav>
		<div class="logo-container">
			<a href="/">
				<img id="logo-eye" src="/eye_green.png" alt="logo" />
			</a>
		</div>
		<div class="internal-links">
			<HeaderLink href="/">home</HeaderLink>
			<HeaderLink href="/blog">blogs</HeaderLink>
			<HeaderLink href="/videos">videos</HeaderLink>
			<button id="theme-toggle" class="theme-switch" aria-label="Toggle Theme">
				<div class="switch-inner"></div>
			</button>
		</div>
	</nav>
</header>

<script>
	const eyes = ['/eye_green.png', '/eye_orange.png', '/eye_yellow.png'];
	const randomEye = eyes[Math.floor(Math.random() * eyes.length)];
	const logoImg = document.getElementById('logo-eye') as HTMLImageElement;
	if (logoImg) {
		logoImg.src = randomEye;
	}

	const toggle = document.getElementById('theme-toggle');
	const body = document.body;

	if (localStorage.getItem('theme') === 'light-mode') {
		body.classList.add('light-mode');
		toggle?.classList.add('active');
	}

	toggle?.addEventListener('click', () => {
		body.classList.toggle('light-mode');
		toggle.classList.toggle('active');
		localStorage.setItem('theme', body.classList.contains('light-mode') ? 'light-mode' : 'dark-mode');
	});
</script>

<style>
	header {
		padding: 1em 2em;
		background: black;
		border-bottom: 1px solid #333;
		display: block;
		margin: 0;
	}
	:global(.light-mode) header {
		background: white;
		border-bottom: 1px solid #ddd;
	}
	.logo-container img {
		height: 80px;
		width: auto;
		display: block;
		border-radius: 12px; /* Less curved, but still rounded */
	}
	nav {
		display: flex;
		align-items: center;
		justify-content: space-between;
	}
	.internal-links {
		display: flex;
		align-items: center;
		gap: 1.5em;
	}
	nav a {
		color: white;
		text-decoration: none;
		text-transform: lowercase;
		font-family: 'Office Code Pro', monospace;
		transition: all 0.3s ease;
	}
	:global(.light-mode) nav a {
		color: black;
	}
	nav a:hover {
		text-shadow: 0px 0px 10px rgba(255, 255, 255, 0.8);
		border-bottom: 1px solid white;
	}
	:global(.light-mode) nav a:hover {
		text-shadow: 0px 0px 10px rgba(0, 0, 0, 0.2);
		border-bottom: 1px solid black;
	}
	nav a.active {
		border-bottom: 1px solid white;
	}
	:global(.light-mode) nav a.active {
		border-bottom: 1px solid black;
	}
	.theme-switch {
		background: #222;
		width: 44px;
		height: 20px;
		border-radius: 10px;
		border: 1px solid #444;
		position: relative;
		cursor: pointer;
		padding: 0;
	}
	.switch-inner {
		width: 14px;
		height: 14px;
		background: white;
		border-radius: 50%;
		position: absolute;
		top: 2px;
		left: 2px;
		transition: 0.2s;
	}
	.theme-switch.active {
		background: #ddd;
	}
	.theme-switch.active .switch-inner {
		left: 26px;
		background: black;
	}
</style>
