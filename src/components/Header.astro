---
import { SITE_TITLE } from '../consts';
import HeaderLink from './HeaderLink.astro';
---
<header>
	<nav>
		<div class="logo-container">
			<a href="/">
				<img id="logo-eye" src="/eye_green.png" alt="logo" />
			</a>
		</div>
		<div class="internal-links">
			<HeaderLink href="/">home</HeaderLink>
			<HeaderLink href="/videos">videos</HeaderLink>
			<button id="theme-toggle" class="theme-switch" aria-label="Toggle Theme">
				<img id="switch-img" src="/light_off.png" alt="light switch" />
			</button>
		</div>
	</nav>
</header>

<script>
	const eyes = ['/eye_green.png', '/eye_orange.png', '/eye_yellow.png'];
	const randomEye = eyes[Math.floor(Math.random() * eyes.length)];
	const logoImg = document.getElementById('logo-eye') as HTMLImageElement;
	if (logoImg) {
		logoImg.src = randomEye;
	}

	const toggle = document.getElementById('theme-toggle');
	const switchImg = document.getElementById('switch-img') as HTMLImageElement;
	const body = document.body;

	const updateSwitch = (theme: string) => {
		if (switchImg) {
			switchImg.src = theme === 'light-mode' ? '/light_on.png' : '/light_off.png';
		}
	};

	if (localStorage.getItem('theme') === 'light-mode') {
		body.classList.add('light-mode');
		updateSwitch('light-mode');
	}

	toggle?.addEventListener('click', () => {
		body.classList.toggle('light-mode');
		const theme = body.classList.contains('light-mode') ? 'light-mode' : 'dark-mode';
		updateSwitch(theme);
		localStorage.setItem('theme', theme);
	});
</script>

<style>
	header {
		padding: 1em 2em;
		background: black;
		border-bottom: 1px solid #333;
	}
	:global(.light-mode) header {
		background: white;
		border-bottom: 1px solid #ddd;
	}
	.logo-container img {
		height: 80px;
		width: auto;
		display: block;
		border-radius: 12px;
	}
	nav {
		display: flex;
		align-items: center;
		justify-content: space-between;
	}
	.internal-links {
		display: flex;
		align-items: center;
		gap: 1.5em;
	}
	nav a {
		color: white;
		text-decoration: none;
		text-transform: lowercase;
		font-family: 'Office Code Pro', monospace;
	}
	:global(.light-mode) nav a {
		color: black;
	}
	nav a.active {
		border-bottom: 1px solid white;
	}
	:global(.light-mode) nav a.active {
		border-bottom: 1px solid black;
	}
	.theme-switch {
		background: transparent;
		border: none;
		cursor: pointer;
		padding: 0;
		display: flex;
		align-items: center;
		margin-left: 1em;
	}
	.theme-switch img {
		height: 40px; /* Adjusting height to fit header */
		width: auto;
		object-fit: contain; /* Handles the extra canvas space */
	}
</style>
