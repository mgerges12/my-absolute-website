---
import { SITE_TITLE } from '../consts';
import HeaderLink from './HeaderLink.astro';
---
<header>
	<nav>
		<div class="logo-container align-absolute">
			<a href="/">
				<img id="logo-eye" src="/eye_green.png" alt="logo" />
			</a>
		</div>
		<div class="internal-links align-absolute">
			<div class="nav-links">
				<HeaderLink href="/">home</HeaderLink>
				<HeaderLink href="/videos">videos</HeaderLink>
			</div>
			<button id="theme-toggle" class="theme-switch" aria-label="Toggle Theme" title="Toggle light/dark theme">
				<img id="switch-img" src="/light_off.png" alt="light switch" />
			</button>
		</div>
	</nav>
</header>

<script>
	const eyes = ['/eye_green.png', '/eye_orange.png', '/eye_yellow.png'];
	const randomEye = eyes[Math.floor(Math.random() * eyes.length)];
	const logoImg = document.getElementById('logo-eye') as HTMLImageElement;
	if (logoImg) {
		logoImg.src = randomEye;
	}

	const toggle = document.getElementById('theme-toggle');
	const switchImg = document.getElementById('switch-img') as HTMLImageElement;
	const body = document.body;

	const updateSwitch = (theme: string) => {
		if (switchImg) {
			switchImg.src = theme === 'light-mode' ? '/light_on.png' : '/light_off.png';
		}
	};

	if (localStorage.getItem('theme') === 'light-mode') {
		body.classList.add('light-mode');
		updateSwitch('light-mode');
	}

	toggle?.addEventListener('click', () => {
		body.classList.toggle('light-mode');
		const theme = body.classList.contains('light-mode') ? 'light-mode' : 'dark-mode';
		updateSwitch(theme);
		localStorage.setItem('theme', theme);
	});
</script>

<style>
	header {
		padding: 4em 2em; /* Balanced 4em on top and bottom */
		background: black;
        margin: 0;
        width: 100%;
	}
	:global(.light-mode) header {
		background: white;
	}
	.align-absolute {
		transform: translateY(50px);
	}
	.logo-container img {
		height: 80px;
		width: auto;
		display: block;
		border-radius: 12px;
	}
	nav {
		display: flex;
		align-items: center;
		justify-content: space-between;
	}
	.internal-links {
		display: flex;
		align-items: center;
		gap: 2.5em;
	}
	.nav-links {
		display: flex;
		gap: 1.5em;
	}
	nav a {
		color: white;
		text-decoration: none;
		text-transform: lowercase;
		font-family: 'Office Code Pro', monospace;
		font-size: 1.2rem;
        display: flex;
        align-items: center;
        padding-bottom: 10px; /* Space for the underline */
	}
	:global(.light-mode) nav a {
		color: black;
	}
	nav a.active {
		border-bottom: 4px solid white; /* Bolder underline sit directly under text */
        margin-bottom: 15px; /* Moves the underline up visually within the container */
	}
	:global(.light-mode) nav a.active {
		border-bottom: 4px solid black;
	}
	.theme-switch {
		background: transparent;
		border: none;
		cursor: url("data:image/svg+xml;utf8,<svg xmlns='http://www.w3.org/2000/svg' width='40' height='48' viewport='0 0 100 100' style='fill:black;font-size:24px;'><text y='50%'>🍖</text></svg>") 16 0, pointer;
		display: flex;
		align-items: center;
		padding: 0;
        transform: translateY(10px); /* Nudging ONLY the switch further down from the 50px base */
	}
	.theme-switch img {
		height: 100px;
		width: auto;
		display: block;
	}
</style>
