---
import type { CollectionEntry } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';

type Props = CollectionEntry<'poems'>['data'] | CollectionEntry<'stories'>['data'];

const { title, description, pubDate, updatedDate, heroImage } = Astro.props;
---

<html lang="en">
	<head>
		<BaseHead title={title} description={description} />
		<style>
			main {
				width: calc(100% - 2em);
				max-width: 100%;
				margin: 0;
			}
			.prose-container {
				width: 1000px; /* Wider for complex indentations */
				max-width: calc(100% - 2em);
				margin: auto;
				padding: 2em 1em;
				color: white;
                text-align: left;
			}
            /* The Absolute Fix: Preformatted Text */
            .writing-content {
                font-family: 'Office Code Pro', monospace !important;
                font-size: 1.1rem;
                line-height: 1.4;
                white-space: pre; /* Forces every tab and space to show */
                overflow-x: auto; /* Adds a scrollbar if an indent is too wide for mobile */
                margin-top: 2rem;
            }
            :global(.light-mode) .prose-container {
                color: black;
            }
			.title-section {
				margin-bottom: 2rem;
				padding: 2em 0;
				text-align: center;
				border-bottom: 1px solid #333;
			}
            :global(.light-mode) .title-section {
                border-bottom: 1px solid #ddd;
            }
			.title-section h1 {
				margin: 0 0 0.5rem 0;
				font-size: 3rem;
                text-transform: uppercase;
			}
			.date {
				margin-bottom: 0.5em;
				color: #888;
			}
		</style>
	</head>

	<body>
		<Header />
		<main>
			<article class="prose-container">
				<div class="title-section">
					<div class="date">
						<FormattedDate date={pubDate} />
					</div>
					<h1>{title}</h1>
				</div>
                <pre class="writing-content"><slot /></pre>
			</article>
		</main>
		<Footer />
	</body>
</html>
