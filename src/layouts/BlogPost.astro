---
import type { CollectionEntry } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';

type Props = CollectionEntry<'poems'>['data'] | CollectionEntry<'stories'>['data'];

const { title, description, pubDate } = Astro.props;

// Specific size logic for different page types
const isVideosPage = title.toLowerCase() === 'videos';
const isWritingList = title.toLowerCase() === 'writing';
const isSecretPage = title === '???';

// Now both main section headers are 4rem
let titleSize = '4rem'; 
---

<html lang="en">
	<head>
		<BaseHead title={title} description={description} />
		<style define:vars={{ titleSize }}>
			main {
				width: calc(100% - 2em);
				max-width: 100%;
				margin: 0;
			}
			.prose-container {
				width: 1000px;
				max-width: calc(100% - 2em);
				margin: auto;
				padding: 0 1em 4em 1em;
				color: inherit;
                text-align: left;
			}
			.title-section {
				margin-bottom: 1.5rem;
				padding: 2.5em 0;
				text-align: center;
				border-bottom: 1px solid #333;
                position: relative;
                display: flex;
                flex-direction: column;
                align-items: center;
                justify-content: center;
                min-height: 100px;
			}
            :global(.light-mode) .title-section {
                border-bottom: 1px solid #ddd;
            }
            .back-link {
                position: absolute;
                left: 0;
                top: 1rem;
                font-size: 1.2rem;
                text-decoration: none;
                color: var(--accent);
                z-index: 10;
            }
            :global(.light-mode) .back-link {
                color: #008000;
            }
			.title-section h1 {
				margin: 0;
				font-size: clamp(1.5rem, 8vw, 3rem); 
                text-transform: uppercase;
                display: block;
                letter-spacing: -1px;
                line-height: 1.1;
                width: 100%;
                padding: 0 4rem; /* Give space for back button */
                word-wrap: break-word;
                text-align: center;
			}
			.date {
				margin-bottom: 0.5em;
				color: #888;
                font-size: 1rem;
			}
		</style>
	</head>

	<body>
		<Header />
		<main>
			<article class="prose-container">
				<div class="title-section">
                    {(!isVideosPage && !isWritingList && !isSecretPage) && <a href="/writing" class="back-link" title="back to writing">← back</a>}
					<div class="date">
						{(!isVideosPage && !isWritingList && !isSecretPage) && <span>Last Updated: <FormattedDate date={pubDate} /></span>}
					</div>
					<h1>{title}</h1>
				</div>
                <slot />
			</article>
		</main>
		<Footer />
	</body>
</html>
