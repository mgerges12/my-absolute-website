---
import type { CollectionEntry } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';

type Props = CollectionEntry<'poems'>['data'] | CollectionEntry<'stories'>['data'];

const { title, description, pubDate, updatedDate, heroImage } = Astro.props;
---

<html lang="en">
	<head>
		<BaseHead title={title} description={description} />
		<style>
			main {
				width: calc(100% - 2em);
				max-width: 100%;
				margin: 0;
			}
			.prose {
				width: 800px;
				max-width: calc(100% - 2em);
				margin: auto;
				padding: 2em 1em;
				color: white;
                /* The Magic: This makes it look exactly like your text editor */
                white-space: pre-wrap; 
                font-family: 'Office Code Pro', monospace !important;
                font-size: 1.1rem;
                line-height: 1.5;
                text-align: left;
			}
            /* Remove standard margins that Markdown adds */
            .prose :global(p) {
                margin: 0;
                padding: 0;
            }
            .prose :global(h1), .prose :global(h2), .prose :global(h3) {
                text-align: left;
                margin-bottom: 1rem;
            }
            :global(.light-mode) .prose {
                color: black;
            }
			.title {
				margin-bottom: 2rem;
				padding: 2em 0;
				text-align: center;
				border-bottom: 1px solid #333;
			}
            :global(.light-mode) .title {
                border-bottom: 1px solid #ddd;
            }
			.title h1 {
				margin: 0 0 0.5em 0;
				font-size: 3rem;
                text-transform: uppercase;
			}
			.date {
				margin-bottom: 0.5em;
				color: #888;
			}
		</style>
	</head>

	<body>
		<Header />
		<main>
			<article>
				<div class="prose">
					<div class="title">
						<div class="date">
							<FormattedDate date={pubDate} />
						</div>
						<h1>{title}</h1>
					</div>
					<slot />
				</div>
			</article>
		</main>
		<Footer />
	</body>
</html>
