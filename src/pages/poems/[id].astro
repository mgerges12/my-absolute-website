---
import { getCollection, render } from 'astro:content';
import Layout from '../../layouts/BlogPost.astro';
import fs from 'node:fs';

export async function getStaticPaths() {
	const poems = await getCollection('poems');
	return poems.map((poem) => ({
		params: { id: poem.id },
		props: poem,
	}));
}

const poem = Astro.props;

// The Ultimate Fix: Replace every single space with a 'Hard' space so the browser can't ignore it.
const filePath = `./src/content/poems/${poem.id}.mdx`;
let rawBody = "";
try {
    const fullContent = fs.readFileSync(filePath, 'utf-8');
    rawBody = fullContent.split('---').slice(2).join('---').trim();
} catch (e) {
    rawBody = poem.body;
}

const rawContent = rawBody
    .replace(/\*\*\*(.*?)\*\*\*/g, '<strong><em>$1</em></strong>')
    .replace(/\*\*(.*?)\*\*/g, '<strong>$1</strong>')
    .replace(/\*(.*?)\*/g, '<em>$1</em>')
    .replace(/ /g, '&nbsp;') // Force EVERY single space
    .replace(/\t/g, '&nbsp;&nbsp;&nbsp;&nbsp;') // Force tabs
    .replace(/\n/g, '<br />'); // Force newlines
---

<Layout title={poem.data.title || poem.id} pubDate={poem.data.pubDate || new Date()}>
	<div class="absolute-rendering" set:html={rawContent}></div>
</Layout>

<style>
    .absolute-rendering {
        font-family: 'Office Code Pro', monospace !important;
        font-size: 1.1rem;
        line-height: 1.6;
        color: inherit;
        background: transparent;
        border: none;
        padding: 0;
        margin: 0;
        text-align: left;
    }
    
    :global(strong) {
        font-weight: bold;
        color: var(--accent);
    }
    :global(.light-mode strong) {
        color: #008000;
    }
</style>
