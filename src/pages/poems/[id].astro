---
import { getCollection, render } from 'astro:content';
import Layout from '../../layouts/BlogPost.astro';
import fs from 'node:fs';

export async function getStaticPaths() {
	const poems = await getCollection('poems');
	return poems.map((poem) => ({
		params: { id: poem.id },
		props: poem,
	}));
}

const poem = Astro.props;

// Use the raw HTML content from our custom loader
let rawContent = poem.body;
let googleStyles = "";

if (rawContent.includes('<style')) {
    const styleMatch = rawContent.match(/<style[^>]*>([\s\S]*)<\/style>/i);
    googleStyles = styleMatch ? styleMatch[1] : "";
    
    const bodyMatch = rawContent.match(/<body[^>]*>([\s\S]*)<\/body>/i);
    if (bodyMatch) {
        rawContent = bodyMatch[1];
    }
}

// 1. Clean up Google's defaults
googleStyles = googleStyles.replace(/background-color:#ffffff/g, 'background-color:transparent');
googleStyles = googleStyles.replace(/font-family:".*?"/g, 'font-family:inherit');
googleStyles = googleStyles.replace(/color:#000000/g, 'color:inherit');

// 2. CRUSH Vertical spacing ONLY (preserve margin-left!)
googleStyles = googleStyles.replace(/padding-top:.*?;/g, 'padding-top:0 !important;');
googleStyles = googleStyles.replace(/padding-bottom:.*?;/g, 'padding-bottom:0 !important;');
googleStyles = googleStyles.replace(/margin-top:.*?;/g, 'margin-top:0 !important;');
googleStyles = googleStyles.replace(/margin-bottom:.*?;/g, 'margin-bottom:0 !important;');
googleStyles = googleStyles.replace(/line-height:.*?;/g, 'line-height:1.1 !important;'); // Slight breathing room, but tight
---

<Layout title={poem.data.title || poem.id} pubDate={poem.data.pubDate || new Date()}>
    {googleStyles && <style set:html={googleStyles}></style>}
	<div class="absolute-rendering" set:html={rawContent}></div>
</Layout>

<style>
    .absolute-rendering {
        font-family: 'Office Code Pro', monospace !important;
        font-size: 1.1rem;
        line-height: 1.1 !important;
        color: inherit;
        background: transparent;
        border: none;
        padding: 0;
        margin: 0;
        text-align: left;
    }
    
    /* Force font and color, but DO NOT touch margin-left */
    .absolute-rendering :global(*) {
        font-family: 'Office Code Pro', monospace !important;
        color: inherit !important;
        background-color: transparent !important;
    }

    /* Surgical Vertical Crush */
    .absolute-rendering :global(p), 
    .absolute-rendering :global(span), 
    .absolute-rendering :global(div),
    .absolute-rendering :global(h1),
    .absolute-rendering :global(h2) {
        margin-top: 0 !important;
        margin-bottom: 0 !important;
        padding-top: 0 !important;
        padding-bottom: 0 !important;
        line-height: 1.1 !important;
    }

    /* Ensure specific Google Docs indent classes work */
    .absolute-rendering :global(ol), .absolute-rendering :global(ul) {
        margin-top: 0 !important;
        margin-bottom: 0 !important;
    }

    :global(strong) {
        font-weight: bold;
        color: var(--accent);
    }
    :global(.light-mode strong) {
        color: #008000;
    }
</style>
