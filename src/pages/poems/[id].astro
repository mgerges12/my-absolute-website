---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/BlogPost.astro';

export async function getStaticPaths() {
	const poems = await getCollection('poems');
	return poems.map((poem) => ({
		params: { id: poem.id },
		props: poem,
	}));
}

const poem = Astro.props;

// THE ULTIMATE TITLE FORMATTER
const formatTitle = (id: string) => {
    let result = id.replace(/([A-Z])/g, ' $1').trim();
    result = result.replace(/-/g, ' ');
    return result
        .split(/\s+/)
        .map(word => {
            const lower = word.toLowerCase();
            if (lower === 'ill') return "I'll";
            if (lower === 'dont') return "Don't";
            if (lower === 'cant') return "Can't";
            if (lower === 'im') return "I'm";
            return word.charAt(0).toUpperCase() + word.slice(1).toLowerCase();
        })
        .join(' ');
};

let rawContent = poem.body;
let googleStyles = "";

const shouldOverride = rawContent.includes('OVERRIDE_STYLE: TRUE');
if (shouldOverride) {
    rawContent = rawContent.replace('OVERRIDE_STYLE: TRUE', '');
}

if (rawContent.includes('<style')) {
    const styleMatch = rawContent.match(/<style[^>]*>([\s\S]*)<\/style>/i);
    googleStyles = styleMatch ? styleMatch[1] : "";
    const bodyMatch = rawContent.match(/<body[^>]*>([\s\S]*)<\/body>/i);
    if (bodyMatch) {
        rawContent = bodyMatch[1];
    }
}

if (!shouldOverride) {
    googleStyles = googleStyles.replace(/background-color:#ffffff/g, 'background-color:transparent');
    googleStyles = googleStyles.replace(/font-family:".*?"/g, 'font-family:inherit');
    googleStyles = googleStyles.replace(/color:#000000/g, 'color:inherit');
    googleStyles = googleStyles.replace(/font-size:.*?;/g, 'font-size:inherit !important;');
    googleStyles = googleStyles.replace(/padding(-top|-bottom)?:.*?;/g, 'padding$1:0 !important;');
    googleStyles = googleStyles.replace(/margin(-top|-bottom)?:.*?;/g, 'margin$1:0 !important;');
    googleStyles = googleStyles.replace(/line-height:.*?;/g, 'line-height:1.4 !important;');
} else {
    // ALWAYS override color, background, and padding to ensure symmetry and contrast
    googleStyles = googleStyles.replace(/background-color:#ffffff/g, 'background-color:transparent');
    googleStyles = googleStyles.replace(/color:#000000/g, 'color:inherit');
    googleStyles = googleStyles.replace(/padding(-top|-bottom)?:.*?;/g, 'padding$1:0 !important;');
    googleStyles = googleStyles.replace(/margin(-top|-bottom)?:.*?;/g, 'margin$1:0 !important;');
}
const finalTitle = formatTitle(poem.id);
---

<Layout title={finalTitle} description={finalTitle} pubDate={poem.data.pubDate || new Date()}>
    {googleStyles && <style set:html={googleStyles}></style>}
	<div class="absolute-rendering" set:html={rawContent}></div>
</Layout>

<style>
    .absolute-rendering {
        width: 100%;
    }
    :global(.absolute-rendering h1), 
    :global(.absolute-rendering h2), 
    :global(.absolute-rendering h3) {
        text-align: center !important;
        width: 100%;
        display: block;
    }
</style>
