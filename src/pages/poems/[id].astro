---
import { getCollection, render } from 'astro:content';
import Layout from '../../layouts/BlogPost.astro';
import fs from 'node:fs';

export async function getStaticPaths() {
	const poems = await getCollection('poems');
	return poems.map((poem) => ({
		params: { id: poem.id },
		props: poem,
	}));
}

const poem = Astro.props;

// Detect if it's an HTML file
const isHtml = poem.id.endsWith('.html');
let rawContent = "";
let googleStyles = "";

if (isHtml) {
    const filePath = `./src/content/poems/${poem.id}`;
    const fullHtml = fs.readFileSync(filePath, 'utf-8');
    
    // 1. Extract ALL styles (this is where staggering lives)
    const styleMatch = fullHtml.match(/<style[^>]*>([\s\S]*)<\/style>/i);
    googleStyles = styleMatch ? styleMatch[1] : "";
    
    // 2. Extract the body content
    const bodyMatch = fullHtml.match(/<body[^>]*>([\s\S]*)<\/body>/i);
    rawContent = bodyMatch ? bodyMatch[1] : fullHtml;
    
    // 3. Cleanup: Remove Google's forced white background and Arial font
    googleStyles = googleStyles.replace(/background-color:#ffffff/g, 'background-color:transparent');
    googleStyles = googleStyles.replace(/font-family:"Arial"/g, 'font-family:inherit');
    googleStyles = googleStyles.replace(/color:#000000/g, 'color:inherit');
} else {
    // Standard renderer for non-HTML files
    rawContent = poem.body
        .replace(/\*\*\*(.*?)\*\*\*/g, '<strong><em>$1</em></strong>')
        .replace(/\*\*(.*?)\*\*/g, '<strong>$1</strong>')
        .replace(/\*(.*?)\*/g, '<em>$1</em>')
        .replace(/ /g, '&nbsp;')
        .replace(/\t/g, '&nbsp;&nbsp;&nbsp;&nbsp;')
        .replace(/\n/g, '<br />');
}
---

<Layout title={poem.data.title || poem.id} pubDate={poem.data.pubDate || new Date()}>
    {isHtml && <style set:html={googleStyles}></style>}
	<div class="absolute-rendering" set:html={rawContent}></div>
</Layout>

<style>
    .absolute-rendering {
        font-family: 'Office Code Pro', monospace !important;
        font-size: 1.1rem;
        line-height: 1.6;
        color: inherit;
        background: transparent;
        border: none;
        padding: 0;
        margin: 0;
        text-align: left;
    }
    
    /* Ensure our font and color choices win */
    .absolute-rendering :global(*) {
        font-family: 'Office Code Pro', monospace !important;
        color: inherit !important;
    }

    :global(strong), .absolute-rendering :global(strong), .absolute-rendering :global(b) {
        font-weight: bold !important;
        color: var(--accent) !important;
    }
    :global(.light-mode strong), :global(.light-mode) .absolute-rendering :global(strong) {
        color: #008000 !important;
    }
</style>
