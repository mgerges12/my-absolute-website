---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/BlogPost.astro';

export async function getStaticPaths() {
	const poems = await getCollection('poems');
	return poems.map((poem) => ({
		params: { id: poem.id },
		props: poem,
	}));
}

const poem = Astro.props;

// The Absolute Force Renderer:
// 1. Preserve Bold/Italic
// 2. Convert Tabs to 4 hard spaces
// 3. Convert multiple spaces to hard spaces
// 4. Convert newlines to physical breaks
const rawContent = poem.body
    .replace(/\*\*\*(.*?)\*\*\*/g, '<strong><em>$1</em></strong>')
    .replace(/\*\*(.*?)\*\*/g, '<strong>$1</strong>')
    .replace(/\*(.*?)\*/g, '<em>$1</em>')
    .replace(/\t/g, '&nbsp;&nbsp;&nbsp;&nbsp;') // Hard-code tabs
    .replace(/  /g, '&nbsp;&nbsp;') // Preserve double spaces
    .replace(/\n/g, '<br />'); // Force every single newline
---

<Layout {...poem.data}>
	<div class="absolute-rendering" set:html={rawContent}></div>
</Layout>

<style>
    .absolute-rendering {
        font-family: 'Office Code Pro', 'Courier New', monospace !important;
        font-size: 1.1rem;
        line-height: 1.6;
        color: inherit;
        background: transparent;
        border: none;
        padding: 0;
        margin: 0;
        text-align: left;
    }
    
    .absolute-rendering strong {
        font-weight: bold;
        color: var(--accent);
    }
    :global(.light-mode) .absolute-rendering strong {
        color: #008000;
    }
</style>
