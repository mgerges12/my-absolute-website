---
import { getCollection, render } from 'astro:content';
import Layout from '../../layouts/BlogPost.astro';
import fs from 'node:fs';

export async function getStaticPaths() {
	const poems = await getCollection('poems');
	return poems.map((poem) => ({
		params: { id: poem.id },
		props: poem,
	}));
}

const poem = Astro.props;

// Detect if it's an HTML file
const isHtml = poem.id.endsWith('.html');
let rawContent = "";

if (isHtml) {
    // Read the HTML file directly and extract the body content
    const filePath = `./src/content/poems/${poem.id}`;
    const fullHtml = fs.readFileSync(filePath, 'utf-8');
    // Grab everything between <body> tags
    const bodyMatch = fullHtml.match(/<body[^>]*>([\s\S]*)<\/body>/i);
    rawContent = bodyMatch ? bodyMatch[1] : fullHtml;
} else {
    // Use the Absolute Force Renderer for Markdown/Text
    rawContent = poem.body
        .replace(/\*\*\*(.*?)\*\*\*/g, '<strong><em>$1</em></strong>')
        .replace(/\*\*(.*?)\*\*/g, '<strong>$1</strong>')
        .replace(/\*(.*?)\*/g, '<em>$1</em>')
        .replace(/ /g, '&nbsp;')
        .replace(/\t/g, '&nbsp;&nbsp;&nbsp;&nbsp;')
        .replace(/\n/g, '<br />');
}
---

<Layout title={poem.data.title || poem.id} pubDate={poem.data.pubDate || new Date()}>
	<div class="absolute-rendering" set:html={rawContent}></div>
</Layout>

<style>
    .absolute-rendering {
        font-family: 'Office Code Pro', monospace !important;
        font-size: 1.1rem;
        line-height: 1.6;
        color: inherit;
        background: transparent;
        border: none;
        padding: 0;
        margin: 0;
        text-align: left;
    }
    
    /* Force Office Code Pro onto Google Docs HTML */
    .absolute-rendering :global(*) {
        font-family: 'Office Code Pro', monospace !important;
    }

    :global(strong) {
        font-weight: bold;
        color: var(--accent);
    }
</style>
