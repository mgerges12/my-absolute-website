---
import { getCollection, render } from 'astro:content';
import Layout from '../../layouts/BlogPost.astro';

export async function getStaticPaths() {
	const poems = await getCollection('poems');
	return poems.map((poem) => ({
		params: { id: poem.id },
		props: poem,
	}));
}

const poem = Astro.props;
// Point to the PDF file in the public folder
const pdfPath = `/${poem.id}.pdf`;
---

<Layout title={poem.data.title || poem.id} pubDate={poem.data.pubDate || new Date()}>
	<div class="pdf-container">
        <embed 
            src={pdfPath} 
            type="application/pdf" 
            width="100%" 
            height="1000px" 
        />
        <div class="pdf-fallback">
            <p>It looks like your browser doesn't support embedded PDFs. 
               <a href={pdfPath}>Click here to view the poem directly.</a>
            </p>
        </div>
    </div>
</Layout>

<style>
    .pdf-container {
        width: 100%;
        margin-top: 2rem;
        border: 1px solid #333;
        background: white; /* PDFs look best on a white page background */
    }
    :global(.light-mode) .pdf-container {
        border: 1px solid #ddd;
    }
    .pdf-fallback {
        padding: 2rem;
        text-align: center;
        display: none; /* Hide unless the embed fails */
    }
</style>
