---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/BlogPost.astro';

export async function getStaticPaths() {
	const poems = await getCollection('poems');
	return poems.map((poem) => ({
		params: { id: poem.id },
		props: poem,
	}));
}

const poem = Astro.props;
// The Magic Fix: We are grabbing the RAW body of the file, ignoring the Markdown cleaner.
const rawContent = poem.body;
---

<Layout {...poem.data}>
	<pre class="raw-writing">{rawContent}</pre>
</Layout>

<style>
    .raw-writing {
        font-family: 'Office Code Pro', monospace !important;
        font-size: 1.1rem;
        line-height: 1.5;
        white-space: pre; /* Forces the browser to show EVERY space and tab */
        color: inherit;
        background: transparent;
        border: none;
        padding: 0;
        margin: 0;
        overflow-x: auto;
    }
</style>
