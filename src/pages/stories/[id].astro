---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/BlogPost.astro';

export async function getStaticPaths() {
	const stories = await getCollection('stories');
	return stories.map((story) => ({
		params: { id: story.id },
		props: story,
	}));
}

const story = Astro.props;

// Smart Title Formatter
const formatTitle = (id: string) => {
    return id
        .split('-')
        .map(word => {
            const lower = word.toLowerCase();
            if (lower === 'ill') return "I'll";
            if (lower === 'dont') return "Don't";
            if (lower === 'cant') return "Can't";
            return word.charAt(0).toUpperCase() + word.slice(1);
        })
        .join(' ');
};

let rawContent = story.body;
let googleStyles = "";

if (rawContent.includes('<style')) {
    const styleMatch = rawContent.match(/<style[^>]*>([\s\S]*)<\/style>/i);
    googleStyles = styleMatch ? styleMatch[1] : "";
    const bodyMatch = rawContent.match(/<body[^>]*>([\s\S]*)<\/body>/i);
    if (bodyMatch) {
        rawContent = bodyMatch[1];
    }
}

googleStyles = googleStyles.replace(/background-color:#ffffff/g, 'background-color:transparent');
googleStyles = googleStyles.replace(/font-family:".*?"/g, 'font-family:inherit');
googleStyles = googleStyles.replace(/color:#000000/g, 'color:inherit');
googleStyles = googleStyles.replace(/font-size:.*?;/g, 'font-size:inherit !important;');
googleStyles = googleStyles.replace(/padding-top:.*?;/g, 'padding-top:0 !important;');
googleStyles = googleStyles.replace(/padding-bottom:.*?;/g, 'padding-bottom:0 !important;');
googleStyles = googleStyles.replace(/margin-top:.*?;/g, 'margin-top:0 !important;');
googleStyles = googleStyles.replace(/margin-bottom:.*?;/g, 'margin-bottom:0 !important;');
googleStyles = googleStyles.replace(/line-height:.*?;/g, 'line-height:1.4 !important;');
---

<Layout title={formatTitle(story.id)} pubDate={story.data.pubDate || new Date()}>
    {googleStyles && <style set:html={googleStyles}></style>}
	<div class="absolute-rendering" set:html={rawContent}></div>
</Layout>

<style>
    .absolute-rendering {
        font-family: 'Office Code Pro', monospace !important;
        font-size: 1.4rem !important;
        line-height: 1.4 !important;
        color: var(--accent) !important;
        background: transparent;
        border: none;
        padding: 0;
        margin: 0;
        text-align: left;
        white-space: pre-wrap !important;
        tab-size: 4 !important;
    }
    
    :global(.light-mode) .absolute-rendering {
        color: #008000 !important;
    }

    .absolute-rendering :global(*) {
        font-family: 'Office Code Pro', monospace !important;
        font-size: 1.4rem !important;
        color: inherit !important;
        margin-top: 0 !important;
        margin-bottom: 0 !important;
        padding: 0 !important;
        line-height: 1.4 !important;
    }

    :global(strong), .absolute-rendering :global(strong), .absolute-rendering :global(b) {
        font-weight: bold !important;
    }
</style>
