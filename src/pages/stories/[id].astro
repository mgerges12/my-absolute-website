---
import { getCollection, render } from 'astro:content';
import Layout from '../../layouts/BlogPost.astro';
import fs from 'node:fs';

export async function getStaticPaths() {
	const stories = await getCollection('stories');
	return stories.map((story) => ({
		params: { id: story.id },
		props: story,
	}));
}

const story = Astro.props;

const isHtml = story.id.endsWith('.html');
let rawContent = "";
let googleStyles = "";

if (isHtml) {
    const filePath = `./src/content/stories/${story.id}`;
    const fullHtml = fs.readFileSync(filePath, 'utf-8');
    const styleMatch = fullHtml.match(/<style[^>]*>([\s\S]*)<\/style>/i);
    googleStyles = styleMatch ? styleMatch[1] : "";
    const bodyMatch = fullHtml.match(/<body[^>]*>([\s\S]*)<\/body>/i);
    rawContent = bodyMatch ? bodyMatch[1] : fullHtml;
} else {
    rawContent = story.body
        .replace(/\*\*\*(.*?)\*\*\*/g, '<strong><em>$1</em></strong>')
        .replace(/\*\*(.*?)\*\*/g, '<strong>$1</strong>')
        .replace(/\*(.*?)\*/g, '<em>$1</em>')
        .replace(/ /g, '&nbsp;')
        .replace(/\t/g, '&nbsp;&nbsp;&nbsp;&nbsp;')
        .replace(/\n/g, '<br />');
}
---

<Layout title={story.data.title || story.id} pubDate={story.data.pubDate || new Date()}>
    {isHtml && <style set:html={googleStyles}></style>}
	<div class="absolute-rendering" set:html={rawContent}></div>
</Layout>

<style>
    .absolute-rendering {
        font-family: 'Office Code Pro', monospace !important;
        font-size: 1.1rem;
        line-height: 1.6;
        color: inherit;
        background: transparent;
        border: none;
        padding: 0;
        margin: 0;
        text-align: left;
    }
    
    .absolute-rendering :global(*) {
        font-family: 'Office Code Pro', monospace !important;
    }

    :global(strong) {
        font-weight: bold;
        color: var(--accent);
    }
</style>
