---
import { getCollection } from 'astro:content';
import Layout from '../layouts/BlogPost.astro';

const safeSort = (a, b) => {
    const dateA = a.data.pubDate ? new Date(a.data.pubDate).valueOf() : 0;
    const dateB = b.data.pubDate ? new Date(b.data.pubDate).valueOf() : 0;
    return dateB - dateA;
};

const videos = (await getCollection('videos')).sort(safeSort);
---

<Layout
	title="videos"
	description="absolute videos"
	pubDate={new Date('March 09 2026')}
>
	<div class="video-container">
        {videos.length > 0 ? (
            <div class="video-grid">
                {videos.map((video) => (
                    <section class="video-item">
                        <h2>{video.data.title}</h2>
                        <div class="video-content">
                            {video.data.videoUrl && (
                                <div class="video-embed">
                                    <iframe 
                                        width="100%" 
                                        height="315" 
                                        src={video.data.videoUrl.replace("watch?v=", "embed/")} 
                                        frameborder="0" 
                                        allowfullscreen
                                    ></iframe>
                                </div>
                            )}
                            <p>{video.data.description}</p>
                            <a href={`/videos/${video.id}/`}>View Details</a>
                        </div>
                    </section>
                ))}
            </div>
        ) : (
            <p>Coming soon...</p>
        )}
    </div>
</Layout>

<style>
    .video-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
        gap: 2rem;
        margin-top: 2rem;
    }
    .video-item {
        border-bottom: 1px solid var(--accent);
        padding-bottom: 1rem;
    }
    .video-item h2 {
        font-size: 1.5rem;
        color: var(--accent);
        margin-bottom: 1rem;
    }
    .video-embed {
        margin-bottom: 1rem;
    }
    a {
        color: inherit;
        text-decoration: underline;
    }
</style>
