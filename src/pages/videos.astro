---
import { getCollection } from 'astro:content';
import Layout from '../layouts/BlogPost.astro';

const safeSort = (a, b) => {
    const dateA = a.data.pubDate ? new Date(a.data.pubDate).valueOf() : 0;
    const dateB = b.data.pubDate ? new Date(b.data.pubDate).valueOf() : 0;
    return dateB - dateA;
};

const videos = (await getCollection('videos')).sort(safeSort);
---

<Layout
	title="videos"
	description="absolute videos"
	pubDate={new Date('March 09 2026')}
>
	<div class="video-canvas">
        {videos.length > 0 ? (
            <div id="scatter-grid" class="video-scatter">
                {videos.map((video) => (
                    <div class="video-wrapper">
                        {video.data.videoUrl && (
                            <iframe 
                                src={video.data.videoUrl.includes('youtu.be') 
                                    ? video.data.videoUrl.replace('youtu.be/', 'www.youtube.com/embed/') 
                                    : video.data.videoUrl.replace('watch?v=', 'embed/')} 
                                frameborder="0" 
                                allowfullscreen
                            ></iframe>
                        )}
                    </div>
                ))}
            </div>
        ) : (
            <p>Coming soon...</p>
        )}
    </div>
</Layout>

<script>
    function randomizeVideos() {
        const wrappers = document.querySelectorAll('.video-wrapper');
        wrappers.forEach((el) => {
            const wrapper = el as HTMLElement;
            // Random size between 300px and 600px
            const size = Math.floor(Math.random() * 300) + 300;
            // Random rotation between -5 and 5 degrees
            const rotation = Math.floor(Math.random() * 10) - 5;
            // Random margins to create scatter
            const marginTop = Math.floor(Math.random() * 100) - 50;
            const marginLeft = Math.floor(Math.random() * 60) - 30;

            wrapper.style.width = `${size}px`;
            wrapper.style.height = `${(size * 9) / 16}px`; // Maintain 16:9
            wrapper.style.transform = `rotate(${rotation}deg)`;
            wrapper.style.marginTop = `${marginTop}px`;
            wrapper.style.marginLeft = `${marginLeft}px`;
        });
    }

    // Run on load
    randomizeVideos();
</script>

<style>
    .video-canvas {
        width: 100vw;
        position: relative;
        left: 50%;
        right: 50%;
        margin-left: -50vw;
        margin-right: -50vw;
        padding: 4rem 2rem;
        overflow-x: hidden;
    }

    .video-scatter {
        display: flex;
        flex-wrap: wrap;
        justify-content: center;
        align-items: center;
        gap: 6rem; /* Huge gaps for scattering */
    }

    .video-wrapper {
        position: relative;
        box-shadow: 0 20px 50px rgba(0,0,0,0.5);
        transition: all 0.5s ease;
        background: black; /* Prevents seeing through before load */
    }

    .video-wrapper:hover {
        transform: scale(1.05) rotate(0deg) !important;
        z-index: 100;
    }

    iframe {
        width: 100%;
        height: 100%;
        display: block;
    }

    @media (max-width: 720px) {
        .video-wrapper {
            width: 90vw !important;
            height: auto !important;
            aspect-ratio: 16/9;
            margin: 2rem auto !important;
            transform: none !important;
        }
    }
</style>
