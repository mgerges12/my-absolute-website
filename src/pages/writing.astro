---
import { getCollection } from 'astro:content';
import Layout from '../layouts/BlogPost.astro';

// Smart Title Formatter
export const formatTitle = (id: string) => {
    let result = id.replace(/([A-Z])/g, ' $1').trim();
    result = result.replace(/-/g, ' ');
    return result
        .split(/\s+/)
        .map(word => {
            const lower = word.toLowerCase();
            if (lower === 'ill') return "I'll";
            if (lower === 'dont') return "Don't";
            if (lower === 'cant') return "Can't";
            if (lower === 'im') return "I'm";
            return word.charAt(0).toUpperCase() + word.slice(1).toLowerCase();
        })
        .join(' ');
};

const safeSort = (a, b) => {
    const dateA = a.data.pubDate ? new Date(a.data.pubDate).valueOf() : 0;
    const dateB = b.data.pubDate ? new Date(b.data.pubDate).valueOf() : 0;
    return dateB - dateA;
};

const poems = (await getCollection('poems')).sort(safeSort);
const stories = (await getCollection('stories')).sort(safeSort);
---

<Layout
	title="writing"
	description="poems and stories from nowhere"
	pubDate={new Date('March 09 2026')}
>
	<div class="writing-container">
        <section class="writing-section">
            <h2>Poems</h2>
            {poems.length > 0 ? (
                <ul>
                    {poems.map((poem) => (
                        <li>
                            <a href={`/poems/${poem.id}/`}>{formatTitle(poem.id)}</a>
                        </li>
                    ))}
                </ul>
            ) : (
                <p>No poems yet...</p>
            )}
        </section>

        <section class="writing-section">
            <h2>Stories</h2>
            {stories.length > 0 ? (
                <ul>
                    {stories.map((story) => (
                        <li>
                            <a href={`/stories/${story.id}/`}>{formatTitle(story.id)}</a>
                        </li>
                    ))}
                </ul>
            ) : (
                <p>No stories yet...</p>
            )}
        </section>
    </div>
</Layout>

<style>
    .writing-container {
        display: flex;
        justify-content: space-between;
        gap: 4rem;
        margin-top: 4rem;
        width: 100%;
    }
    .writing-section {
        flex: 1;
    }
    .writing-section h2 {
        border-bottom: 1px solid var(--accent);
        padding-bottom: 0.5rem;
        margin-bottom: 1.5rem;
        text-align: left;
        color: var(--accent);
    }
    :global(.light-mode) .writing-section h2 {
        color: #008000;
        border-bottom: 1px solid #008000;
    }
    ul {
        list-style: none;
        padding: 0;
        text-align: left;
    }
    li {
        margin-bottom: 1rem;
    }
    a {
        font-size: 1.2rem;
        border: none !important;
        color: inherit;
    }
    a:hover {
        text-shadow: 0 0 10px rgba(0, 255, 0, 0.5);
    }
    :global(.light-mode) a:hover {
        text-shadow: 0 0 10px rgba(0, 128, 0, 0.2);
    }
    @media (max-width: 720px) {
        .writing-container {
            flex-direction: column;
            gap: 2rem;
        }
    }
</style>
